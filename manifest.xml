<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="MailApp">

  <!-- ★ GUIDは一意である必要があります。変更不要です -->
  <Id>4f8a2b1c-3d9e-4f2a-8b1c-3d9e4f2a8b1c</Id>
  <Version>1.0.0</Version>
  <ProviderName>ARM</ProviderName>
  <DefaultLocale>ja-JP</DefaultLocale>
  <DisplayName DefaultValue="クラウドログ挿入"/>
  <Description DefaultValue="予定作成時にクラウドログコードを挿入します"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <!-- ★ ここをホスト先のURLに変更してください -->
        <SourceLocation DefaultValue="https://takt-doi.github.io/cloudlog-addin/taskpane.html"/>
        <RequestedHeight>220</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Edit"/>
  </Rule>

</OfficeApp>
